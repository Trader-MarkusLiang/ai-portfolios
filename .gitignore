# secrets / env
.env
.env.*
!.env.example

# python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# data: ignore everything except last_seen.json (persisted across runs)
data/*
!data/.gitkeep
!data/last_seen.json
!data/wechat_articles/
!data/wechat_articles/**

# reports: ignore generated files but keep folder
reports/*
!reports/.gitkeep
!reports/summaries/
!reports/summaries/.gitkeep
!reports/summaries/*.md

# os / editor
.DS_Store
.idea/
.vscode/

# local WeWe RSS data
docker/wewe-rss/data/

# WeChat group raw messages stay local by default
data/wechat_groups/inbox/
data/wechat_groups/processed/
!data/wechat_groups/
!data/wechat_groups/summaries/
!data/wechat_groups/summaries/**
