# twitterapi.io (used only as fallback when Nitter fails)
TWITTERAPI_IO_KEY=

# Discord webhook (channel webhook URL)
DISCORD_WEBHOOK_URL=

# LLM（火山方舟 OpenAI 兼容接口）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3  # 固定 coding 接入点
ARK_PLANNER_MODEL=kimi-k2.7-code  # 慢模型：只负责报告目录、核心点和逻辑骨架
ARK_WRITER_MODEL=minimax-m3  # 快模型：负责最终报告文本成文
ARK_PLANNER_FALLBACK_MODELS=minimax-m3
ARK_WRITER_FALLBACK_MODELS=doubao-seed-2.0-lite,deepseek-v4-flash
ARK_PLANNER_TIMEOUT_SECONDS=20
ARK_WRITER_TIMEOUT_SECONDS=45

# Optional: explicitly allow falling back to twitterapi.io. Defaults to ON
# whenever TWITTERAPI_IO_KEY is present, OFF otherwise.
# ALLOW_TWITTERAPI_IO_FALLBACK=1
